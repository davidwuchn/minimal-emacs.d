{
  "workflow": "code_agent",
  "version": "1.0",
  "metadata": {
    "category": "execution",
    "description": "Tests for gptel code agent workflow with tool orchestration"
  },
  "test_cases": [
    {
      "id": "code-001",
      "name": "add_simple_function",
      "description": "Agent should add a simple utility function",
      "task": "Add a function `my/transpose-strings` to lisp/modules/gptel-workflow-benchmark.el that takes two strings and returns them concatenated in reverse order (second + first). Include a brief docstring.",
      "context": {
        "language": "elisp",
        "target_file": "lisp/modules/gptel-workflow-benchmark.el"
      },
      "success_criteria": {
        "completion": {
          "must_complete": true,
          "timeout_seconds": 120,
          "allow_continuation": true
        },
        "efficiency": {
          "min_steps": 2,
          "max_steps": 15,
          "max_continuations": 3,
          "max_duration_seconds": 90
        },
        "tools": {
          "required": ["read", "edit"],
          "forbidden_before_phase": {}
        },
        "phases": {
          "expected": []
        },
        "eight_keys": {
          "min_overall": 0.6
        }
      },
      "expected_outputs": {
        "artifacts": ["function added"],
        "file_operations": ["modify:lisp/modules/gptel-workflow-benchmark.el"]
      }
    },
    {
      "id": "code-002",
      "name": "find_and_document",
