{
  "manifest_version": 3,
  "name": "CreatorOS — Product Intelligence for Creators",
  "version": "0.1.0",
  "description": "Product matching engine overlay for TikTok and Amazon creators. Shows what to promote, margins, and supplier data inline.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.amazon.co.uk/*",
    "https://*.amazon.de/*",
    "https://*.tiktok.com/*",
    "https://www.reddit.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.com/*/dp/*",
        "https://*.amazon.com/dp/*",
        "https://*.amazon.co.uk/*/dp/*",
        "https://*.amazon.de/*/dp/*"
      ],
      "js": ["src/content.js"],
      "css": ["src/overlay.css"]
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": "icons/icon48.png"
  }
}
