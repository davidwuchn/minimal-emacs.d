#!/usr/bin/env bash
# Pre-commit hook for PMF Value Stream / GTM Product Org
# - Blocks commits with merge conflict markers
# - Blocks commits of worktree/temporary files
# - Verifies submodule sync
# - Structural checks staged .el files (parens, top-level definitions)
# - Byte-compiles staged .el files

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"

# Get list of staged files
staged_files=$(git diff --cached --name-only --diff-filter=ACM)

# ─── 1. Detect merge conflict markers ───
echo "pre-commit: checking for merge conflict markers..."
conflict_files=$(echo "$staged_files" | xargs -I{} grep -lE '^\u003c\u003c\u003c\u003c\u003c\u003c\u003c |^=======|^\u003e\u003e\u003e\u003e\u003e\u003e\u003e ' {} 2>/dev/null || true)
if [[ -n "$conflict_files" ]]; then
    echo "pre-commit: ERROR — merge conflict markers found in:"
    echo "$conflict_files"
    echo "pre-commit: Resolve conflicts before committing."
    exit 1
fi

# ─── 2. Block worktree and temporary files ───
while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    if echo "$file" | grep -qE "(var/tmp/experiments/|var/tmp/worktree/|staging-verify)"; then
        echo "ERROR: Attempting to commit worktree file: $file"
        echo "Worktree files must be committed from within the worktree, not the mayor checkout."
        exit 1
    fi
    if echo "$file" | grep -qE "(\.tmp$|\.bak$|~$|experiment-[0-9]|\.tmp\.)"; then
        echo "ERROR: Attempting to commit temporary/experiment file: $file"
        echo "Clean up temporary files before committing to main branch."
        exit 1
    fi
done <<< "$staged_files"

# ─── 3. Check submodule sync ───
if [[ "${VERIFY_NUCLEUS_SKIP_SUBMODULE_SYNC:-0}" == "1" ]]; then
    echo "pre-commit: skipping cached submodule sync (VERIFY_NUCLEUS_SKIP_SUBMODULE_SYNC=1)"
else
    "$repo_root/scripts/check-submodule-sync.sh" --cached
fi

# ─── 4. Structural checks for staged .el files ───
staged_el_files=$(echo "$staged_files" | grep '\.el$' || true)
if [[ -n "$staged_el_files" ]]; then
    echo "pre-commit: running structural checks on staged .el files..."
    failed=0
    while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        if [[ -f "$repo_root/$file" ]]; then
            pkg_load_args=()
            for pkg_dir in "$repo_root/var/elpa"/*/; do
                [[ -d "$pkg_dir" ]] && pkg_load_args+=(-L "$pkg_dir")
            done
            for pkg_dir in "$repo_root/packages"/*/; do
                [[ -d "$pkg_dir" ]] && pkg_load_args+=(-L "$pkg_dir")
            done

            # 4a. check-parens / forward-sexp pass
            if ! emacs -Q --batch \
                    -L "$repo_root" -L "$repo_root/lisp" -L "$repo_root/lisp/modules" \
                    "${pkg_load_args[@]}" \
                    --eval "(with-temp-buffer (insert-file-contents \"$repo_root/$file\") (delay-mode-hooks (emacs-lisp-mode)) (goto-char (point-min)) (while (not (eobp)) (forward-sexp)))" \
                    >/dev/null 2>&1; then
                echo "  FAIL: $file — unbalanced parentheses or unreadable structure"
                failed=1
                continue
            fi

            # 4b. Ensure every defun/cl-defun/defmacro/defconst/defvar/defcustom/defgroup/defsubst/defface is at top level.
            # This catches misplaced parens that swallow later definitions (e.g. defun inside defun),
            # but allows defs inside top-level conditionals such as (when (daemonp) ...).
            check_script='/tmp/pre-commit-top-level-def-check.el'
            cat > "$check_script" <<'CHECK_EOF'
(let ((file (car command-line-args-left))
      (errors nil))
  (with-temp-buffer
    (insert-file-contents file)
    (delay-mode-hooks (emacs-lisp-mode))
    (goto-char (point-min))
    (while (re-search-forward "^(\\(defun\\|cl-defun\\|defmacro\\|defconst\\|defvar\\|defcustom\\|defgroup\\|defsubst\\|defface\\)\\s-+\\(\\S-+\\)" nil t)
      (let ((name (match-string 2))
            (pos (match-beginning 0)))
        (goto-char pos)
        (let* ((state (syntax-ppss))
               (depth (car state))
               (stringp (nth 3 state))
               (commentp (nth 4 state))
               (outer-start (nth 1 state))
               outer-head)
          (when (and (> depth 0)
                     (not stringp)
                     (not commentp)
                     outer-start
                     (save-excursion
                       (goto-char outer-start)
                       (looking-at "(\\s-*\\(\\(?:cl-\\)?defun\\|defmacro\\|defsubst\\)\\_>")))
            (push (format "%s:%d: %s is nested inside %s (not top-level)"
                          file pos name
                          (progn
                            (goto-char outer-start)
                            (forward-char)
                            (skip-syntax-forward " ")
                            (symbol-name (read (current-buffer)))))
                  errors)))
        (goto-char (match-end 0))))
    (if errors
        (progn
          (dolist (e (nreverse errors)) (message "%s" e))
          (kill-emacs 1))
      (message "OK: top-level definitions in %s" file))))
CHECK_EOF
            if ! check_out=$(emacs -Q --batch \
                    -L "$repo_root" -L "$repo_root/lisp" -L "$repo_root/lisp/modules" \
                    "${pkg_load_args[@]}" \
                    -l "$check_script" "$repo_root/$file" 2>&1); then
                echo "$check_out"
                echo "  FAIL: $file — nested top-level definition detected"
                failed=1
                rm -f "$check_script"
                continue
            fi
            rm -f "$check_script"
            echo "$check_out" | grep "^OK:" || true
        fi
    done <<< "$staged_el_files"
    if [[ $failed -ne 0 ]]; then
        echo "pre-commit: structural errors found. Fix before committing."
        exit 1
    fi
fi

# ─── 5. Byte-compile staged .el files ───
staged_el_files=$(echo "$staged_files" | grep '\.el$' || true)
if [[ -n "$staged_el_files" ]]; then
    echo "pre-commit: byte-compiling staged .el files..."
    failed=0
    while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        if [[ -f "$repo_root/$file" ]]; then
            pkg_load_args=()
            for pkg_dir in "$repo_root/var/elpa"/*/; do
                [[ -d "$pkg_dir" ]] && pkg_load_args+=(-L "$pkg_dir")
            done
            for pkg_dir in "$repo_root/packages"/*/; do
                [[ -d "$pkg_dir" ]] && pkg_load_args+=(-L "$pkg_dir")
            done
            if compile_out=$(emacs -Q --batch \
                -L "$repo_root" -L "$repo_root/lisp" -L "$repo_root/lisp/modules" \
                "${pkg_load_args[@]}" \
                --eval "(setq byte-compile-error-on-warn t)" \
                -f batch-byte-compile "$repo_root/$file" 2>&1); then
                compile_exit=0
            else
                compile_exit=$?
            fi
            # Filter output: remove "Wrote" noise and known false-positive warnings
            # (variables used inside lambdas/closures show as "unused"/"free")
            filtered_out=$(echo "$compile_out" | grep -v "^Wrote " | \
                grep -v -E "(Error:|Warning:).*Unused lexical variable" | \
                grep -v -E "(Error:|Warning:).*reference to free variable" | \
                grep -v -E "(Error:|Warning:).*the function .* is not known to be defined" || true)
            echo "$filtered_out"
            # Clean up .elc to avoid committing it
            rm -f "$repo_root/${file}c"
            # Check if there are real errors remaining after filtering
            if echo "$filtered_out" | grep -qE "Error:|error:" ; then
                echo "  FAIL: $file"
                failed=1
            fi
        fi
    done <<< "$staged_el_files"
    if [[ $failed -ne 0 ]]; then
        echo "pre-commit: .el syntax errors found. Fix before committing."
        exit 1
    fi
fi

echo "pre-commit: all checks passed."
exit 0
