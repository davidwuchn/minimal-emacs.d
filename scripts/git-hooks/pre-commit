#!/usr/bin/env bash

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"

# Check for merge conflict markers in staged files
echo "pre-commit: checking for merge conflict markers..."
conflict_files=$(git diff --cached --name-only --diff-filter=ACM | xargs -I{} grep -lE '^<<<<<<< |^=======|^>>>>>>> ' {} 2>/dev/null || true)
if [[ -n "$conflict_files" ]]; then
    echo "pre-commit: ERROR — merge conflict markers found in:" 
    echo "$conflict_files"
    echo "pre-commit: Resolve conflicts before committing."
    exit 1
fi

# Check submodule sync first
if [[ "${VERIFY_NUCLEUS_SKIP_SUBMODULE_SYNC:-0}" == "1" ]]; then
    echo "pre-commit: skipping cached submodule sync (VERIFY_NUCLEUS_SKIP_SUBMODULE_SYNC=1)"
else
    "$repo_root/scripts/check-submodule-sync.sh" --cached
fi

# Byte-compile staged .el files to catch syntax errors (e.g. unbalanced parens)
staged_el_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.el$' || true)
if [[ -n "$staged_el_files" ]]; then
    echo "pre-commit: byte-compiling staged .el files..."
    failed=0
    while IFS= read -r file; do
        if [[ -f "$repo_root/$file" ]]; then
            pkg_load_args=()
            for pkg_dir in "$repo_root/var/elpa"/*/; do
                [[ -d "$pkg_dir" ]] && pkg_load_args+=(-L "$pkg_dir")
            done
            for pkg_dir in "$repo_root/packages"/*/; do
                [[ -d "$pkg_dir" ]] && pkg_load_args+=(-L "$pkg_dir")
            done
            if compile_out=$(emacs -Q --batch \
                -L "$repo_root" -L "$repo_root/lisp" -L "$repo_root/lisp/modules" \
                "${pkg_load_args[@]}" \
                --eval "(setq byte-compile-error-on-warn t)" \
                -f batch-byte-compile "$repo_root/$file" 2>&1); then
                compile_exit=0
            else
                compile_exit=$?
            fi
            # Filter output: remove "Wrote" noise and known false-positive warnings
            # (variables used inside lambdas/closures show as "unused"/"free")
            filtered_out=$(echo "$compile_out" | grep -v "^Wrote " | \
                grep -v -E "(Error:|Warning:).*Unused lexical variable" | \
                grep -v -E "(Error:|Warning:).*reference to free variable" | \
                grep -v -E "(Error:|Warning:).*the function .* is not known to be defined" || true)
            echo "$filtered_out"
            # Clean up .elc to avoid committing it
            rm -f "$repo_root/${file}c"
            # Check if there are real errors remaining after filtering
            if echo "$filtered_out" | grep -qE "Error:|error:" ; then
                echo "  FAIL: $file"
                failed=1
            fi
        fi
    done <<< "$staged_el_files"
    if [[ $failed -ne 0 ]]; then
        echo "pre-commit: .el syntax errors found. Fix before committing."
        exit 1
    fi
fi
